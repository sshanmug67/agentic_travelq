# ============================================================================
# TravelQ — Production Environment Variables
# ============================================================================
#
# SETUP:
#   cp .env.prod.example .env.prod
#   nano .env.prod    # Fill in your real values
#
# WARNING: NEVER commit .env.prod to Git!
#
# PRIORITY: These environment variables override everything in
#           app_config.yaml and backend/.env
#
# USED BY: FastAPI backend + Celery worker (both containers read this file)
# ============================================================================


# ============================================================================
# APPLICATION
# ============================================================================
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO


# ============================================================================
# LLM / OPENAI
# ============================================================================
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small


# ============================================================================
# AMADEUS API (Flights)
# ============================================================================
# Note: Your settings.py accepts both naming conventions:
#   AMADEUS_API_Key / AMADEUS_API_Secret  (original .env format)
#   AMADEUS_CLIENT_ID / AMADEUS_CLIENT_SECRET  (app_config format)
AMADEUS_API_Key=your_amadeus_api_key
AMADEUS_API_Secret=your_amadeus_api_secret


# ============================================================================
# GOOGLE PLACES API (Restaurants & Activities)
# ============================================================================
GOOGLE_PLACES_API_KEY=your_google_places_key


# ============================================================================
# WEATHER API
# ============================================================================
# Open-Meteo is free and doesn't need a key.
# If using OpenWeather or WeatherAPI, uncomment:
# WEATHER_API_KEY=your_weather_key
# WEATHER_PROVIDER=openweather


# ============================================================================
# XOTELO API (Hotels)
# ============================================================================
# If Xotelo requires a key, uncomment:
# XOTELO_API_KEY=your_xotelo_key


# ============================================================================
# TICKETMASTER (Events) — Optional
# ============================================================================
# TICKETMASTER_API_KEY=your_ticketmaster_key


# ============================================================================
# REDIS (Internal Docker Network — DO NOT CHANGE)
# ============================================================================
# These use Docker service names, not localhost
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# ============================================================================
# CORS
# ============================================================================
# Comma-separated allowed origins. Update with your actual domain.
CORS_ORIGINS=https://travelq.yourdomain.com,http://localhost:5173


# ============================================================================
# API SERVER
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api


# ============================================================================
# SUPABASE (Add when ready to integrate database)
# ============================================================================
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIs...


# ============================================================================
# AGENT CONFIGURATION (Optional — defaults are in app_config.yaml)
# ============================================================================
# Uncomment to override app_config.yaml values:
# FLIGHT_AGENT_MAX_RESULTS=10
# HOTEL_AGENT_MAX_RESULTS=15
# WEATHER_AGENT_FORECAST_DAYS=5
# EVENTS_AGENT_MAX_RESULTS=20
# PLACES_AGENT_MAX_RESULTS=50
# PLACES_RESTAURANTS_MAX_RESULTS=15
# PLACES_ACTIVITIES_MAX_RESULTS=15
# AUTOGEN_TIMEOUT=120
# AUTOGEN_CACHE_SEED=42


# ============================================================================
# CACHING (Optional — defaults are in app_config.yaml)
# ============================================================================
# CACHE_ENABLED=true
# CACHE_TTL_SECONDS=300
# CACHE_FLIGHT_TTL=1800
# CACHE_WEATHER_TTL=3600
# CACHE_EVENTS_TTL=86400
